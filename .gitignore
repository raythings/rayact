.DS_Store

# Dependencies
node_modules/

# Build outputs
build/
dist/
.gradle/
.cxx/
*.apk
local.properties
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json

# Generated bundles / bytecode
*.jsc
*.qjsbc
*.rayactpack
# Packaged tarballs (build outputs — produced by npm pack / CI)
*.tgz

# Prebuilt native binaries — shipped via GitHub Releases / npm pack, never git
packages/prebuilt-*/jni/
packages/prebuilt-*/bin/
packages/prebuilt-*/modules/
packages/prebuilt-ios-arm64/RayactEngine.xcframework/
packages/rayact-mmkv/android/
packages/rayact-mmkv/darwin-arm64/
packages/rayact-secure-store/android/
packages/rayact-secure-store/darwin-arm64/

# Build caches / generated app assets
apps/ios/.xcode-derived/
apps/*/rayact-assets/
test-projects/*/rayact-assets/
__pycache__/
.rayact/
.tmp/

# Web / Emscripten build trees
build-web/
build-web-*/

# Vitepress docs build/cache (site is regenerated by CI)
docs/.vitepress/dist/
docs/.vitepress/cache/

# Scratch / temp build helpers (not part of the published source)
.tmp-bundler.*
/window_dump.xml
/tamer-screen/
/KeyboardAvoidingView
/Handoff: *.md

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
