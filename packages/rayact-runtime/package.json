{
  "name": "@rayact/runtime",
  "version": "0.0.1",
  "description": "Renderer-agnostic Rayact host runtime and dev client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc; node scripts/copy-shared.mjs",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/node": "^22.20.0"
  },
  "license": "MIT",
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raythings/rayact.git",
    "directory": "packages/rayact-runtime"
  },
  "homepage": "https://github.com/raythings/rayact#readme",
  "bugs": {
    "url": "https://github.com/raythings/rayact/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "default": "./dist/shared/index.js"
    },
    "./quickjs": {
      "types": "./dist/quickjs/index.d.ts",
      "default": "./dist/quickjs/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "default": "./dist/crypto/index.js"
    },
    "./material-icons": {
      "types": "./dist/shared/material_icons.d.ts",
      "default": "./dist/shared/material_icons.js"
    },
    "./fonts": {
      "types": "./dist/fonts.d.ts",
      "default": "./dist/fonts.js"
    }
  }
}
