{
  "name": "@rayact/prebuild",
  "version": "0.0.3",
  "description": "Rayact native project generation and module autolinking",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=22 <25"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT",
  "maintainers": [
    "Rayact Maintainers"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/raythings/rayact.git",
    "directory": "packages/rayact-prebuild"
  }
}
