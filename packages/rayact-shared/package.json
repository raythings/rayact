{
  "name": "@rayact/shared",
  "version": "0.1.0",
  "description": "Shared types and utilities for rayact",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./material-icons": {
      "types": "./src/material_icons.d.ts",
      "default": "./dist/material_icons.js"
    }
  },
  "files": [
    "dist",
    "src/material_icons.js",
    "src/material_icons.d.ts"
  ],
  "scripts": {
    "build": "tsc && cp src/material_icons.js dist/material_icons.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "shared",
    "types",
    "utilities"
  ],
  "license": "MIT"
}
