{
  "name": "rayact-desktop-smoke",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Standalone Rayact desktop app — Vite + rayact dev server",
  "scripts": {
    "dev": "rayact dev",
    "build": "rayact build --release",
    "build:desktop": "rayact build --release --desktop",
    "build:android": "rayact build --release --android",
    "build:android:install": "rayact build --release --android --install",
    "build:debug": "vite build",
    "start": "rayact start",
    "start:dev": "rayact start --dev",
    "test:desktop": "bash test-desktop.sh"
  },
  "dependencies": {
    "rayact": "file:../..",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "react-refresh": "^0.18.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.6"
  }
}
