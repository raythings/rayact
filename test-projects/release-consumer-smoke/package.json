{
  "name": "release-consumer-smoke",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Consumer smoke test using packed release1 tarballs",
  "scripts": {
    "dev": "rayact dev",
    "dev:web": "rayact dev --web",
    "android": "rayact dev-app --android",
    "ios": "rayact dev-app --ios-simulator",
    "prebuild": "rayact prebuild",
    "android:dev-client": "rayact build --debug --android --install",
    "ios:dev-client": "rayact build --debug --ios --install",
    "build": "rayact build --release",
    "build:desktop": "rayact build --release --desktop",
    "build:web": "rayact build --web",
    "build:android": "rayact build --release --android",
    "build:android:install": "rayact build --release --android --install",
    "build:ios": "rayact build --release --ios",
    "build:ios:install": "rayact build --release --ios --install",
    "serve:web": "rayact serve dist/web",
    "start": "rayact start",
    "start:dev": "rayact start --dev"
  },
  "dependencies": {
    "rayact": "file:../../release1/rayact-0.0.1.tgz",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.2.6"
  },
  "overrides": {
    "@rayact/cli": "file:../../release1/rayact-cli-0.0.1.tgz",
    "@rayact/core": "file:../../release1/rayact-core-0.0.1.tgz",
    "@rayact/crypto": "file:../../release1/rayact-crypto-0.0.1.tgz",
    "@rayact/dev-client": "file:../../release1/rayact-dev-client-0.0.1.tgz",
    "@rayact/dev-server": "file:../../release1/rayact-dev-server-0.0.1.tgz",
    "@rayact/mmkv": "file:../../release1/rayact-mmkv-0.0.1.tgz",
    "@rayact/navigation": "file:../../release1/rayact-navigation-0.0.1.tgz",
    "@rayact/prebuild": "file:../../release1/rayact-prebuild-0.0.1.tgz",
    "@rayact/quickjs": "file:../../release1/rayact-quickjs-0.0.1.tgz",
    "@rayact/react": "file:../../release1/rayact-react-0.0.1.tgz",
    "@rayact/renderer": "file:../../release1/rayact-renderer-0.0.1.tgz",
    "@rayact/runtime": "file:../../release1/rayact-runtime-0.0.1.tgz",
    "@rayact/secure-store": "file:../../release1/rayact-secure-store-0.0.1.tgz",
    "@rayact/shared": "file:../../release1/rayact-shared-0.0.1.tgz",
    "@rayact/types": "file:../../release1/rayact-types-0.0.1.tgz",
    "@rayact/worklets": "file:../../release1/rayact-worklets-0.0.1.tgz",
    "create-rayact-app": "file:../../release1/create-rayact-app-0.0.1.tgz"
  }
}
