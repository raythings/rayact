<?xml version="1.0" encoding="utf-8"?>
<!-- Pushed screen exits when another push happens on top of it.
     The new screen slides over, so the previous one just stays put under it. -->
<alpha xmlns:android="http://schemas.android.com/apk/res/android"
    android:fromAlpha="1.0"
    android:toAlpha="1.0"
    android:duration="250" />
